[gd_scene format=3 uid="uid://gameover_scene"]

[ext_resource type="Script" path="res://scripts/ui/GameOver.gd" id="1"]

[node name="GameOver" type="Control"]
script = ExtResource("1")
anchor_right = 1.0
anchor_bottom = 1.0
process_mode = 3

[node name="BG" type="ColorRect" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.0, 0.0, 0.0, 0.72)

[node name="VBox" type="VBoxContainer" parent="."]
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -160.0
offset_top = -90.0
offset_right = 160.0
offset_bottom = 90.0
theme_override_constants/separation = 20

[node name="Title" type="Label" parent="VBox"]
text = "GAME OVER"
horizontal_alignment = 1
theme_override_colors/font_color = Color(1.0, 0.2, 0.2, 1.0)
theme_override_font_sizes/font_size = 38

[node name="RetryBtn" type="Button" parent="VBox"]
text = "返回复活点"
custom_minimum_size = Vector2(320, 48)
theme_override_font_sizes/font_size = 18

[node name="MenuBtn" type="Button" parent="VBox"]
text = "返回主菜单"
custom_minimum_size = Vector2(320, 48)
theme_override_font_sizes/font_size = 18

[connection signal="pressed" from="VBox/RetryBtn" to="." method="_on_retry_pressed"]
[connection signal="pressed" from="VBox/MenuBtn"  to="." method="_on_main_menu_pressed"]
