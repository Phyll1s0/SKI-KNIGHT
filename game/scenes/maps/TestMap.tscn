; ══════════════════════════════════════════════════════════════════
;  MAP LAYOUT  (Camera in Player.tscn follows player, zoom=1.5)
;
;  x=0──900   Zone1 Tutorial   : flat ground, slope, 2 enemies
;  x=900──1080               PIT 1 (180px) — normal jump clears it
;  x=1080─1280  Zone2 Post-pit : guard IceTurret on ledge
;  x=1280─1680  Mountain Left  : slope going UP-right (decelerate)
;  x=1680─2180  Mountain Right : ski slope going DOWN-right (accelerate)
;  x=2180─2380  Flat after ski : enemies at high speed
;  x=2380─2580               PIT 2 (200px) — needs momentum jump
;  x=2580─3040  Zone3 Final    : 2 enemies, Turret, Portal
; ══════════════════════════════════════════════════════════════════

; ── Root ────────────────────────────────────────────────────────────────
[node name="TestMap" type="Node2D"]
script = ExtResource("2")
area_title = "雪山入口"
drop_equipment_on_death = true

; ── Background（雪山入口：晴空蓝白）─────────────────────────────────────
